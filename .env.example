# Copy this file to .env and fill in your values.
# The .env file is gitignored and must NEVER be committed.

# PostgreSQL connection string
DATABASE_URL=postgresql://<your_pg_user>@localhost:5433/cyberlearn?sslmode=disable

# Secret used to sign JWT access tokens — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret

# Port for both the API server and the Vite dev server
PORT=5000

# URL base path — use / for local development
BASE_PATH=/

# Environment mode
NODE_ENV=development
