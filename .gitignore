# =============================================================================
# CyberLearn LMS — .gitignore
# Stack: Node.js 24, TypeScript, pnpm workspaces, React/Vite, PostgreSQL
# =============================================================================

# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
tmp/
out-tsc/
*.tsbuildinfo

# ── Vite ─────────────────────────────────────────────────────────────────────
artifacts/cyberlearn/dist/

# ── Uploaded Media (user/course content) ─────────────────────────────────────
# Seed assets (sample-*.*, video-*.*, pdf-*.pdf) are committed intentionally.
# Ignore only user-uploaded runtime files that shouldn't be in source control.
# To ignore all uploads in production, uncomment the line below:
# uploads/

# ── Database Local Data ───────────────────────────────────────────────────────
db-data/
*.sql.bak
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── OS & System Files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs & Editors ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
*.launch

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
.expo/
.expo-shared/

# ── Cache ─────────────────────────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache
.stylelintcache
*.tgz

# ── Coverage & Testing ────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Replit specific ───────────────────────────────────────────────────────────
.local/
.replit.nix

# ── Misc ──────────────────────────────────────────────────────────────────────
.sass-cache/
connect.lock
/libpeerconnection.log
typings/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
